---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Biotoco — Tecnologia que Cultiva o Futuro' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Biotoco</title>

    <!-- Preload critical fonts -->
    <link rel="preload" href="/fonts/Kufam-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Poppins-Regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logos/simbolo-principal-azul.png" />

    <meta name="theme-color" content="#EDEBDE" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Biotoco`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="Biotoco" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | Biotoco`} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Biotoco",
      "legalName": "TOCO Engenharia e Inovação Ambiental Ltda",
      "url": "https://biotoco.com.br",
      "description": "Módulos orgânicos biodegradáveis para produção de mudas. Tecnologia patenteada de formação a vácuo de biomassas agroindustriais.",
      "foundingDate": "2017",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Rio Claro",
        "addressRegion": "SP",
        "addressCountry": "BR"
      },
      "sameAs": [
        "https://www.linkedin.com/company/biotoco",
        "https://www.instagram.com/biotoco"
      ]
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
