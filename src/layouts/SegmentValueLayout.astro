---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  fullBleed?: boolean;
}

const { title, description, fullBleed = false } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Fragment slot="default">
    <Nav />
    <!-- Hero slot: full-width, outside container -->
    <slot name="hero" />
    {fullBleed ? (
      <main>
        <slot />
      </main>
    ) : (
      <main class="mx-auto max-w-[1280px] px-4 py-16 md:px-6 md:py-20 lg:px-8">
        <slot />
      </main>
    )}
    <Footer />
  </Fragment>
</BaseLayout>
