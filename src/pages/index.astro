---
import HeroHubLayout from '../layouts/HeroHubLayout.astro';
import Hero from '../components/Hero.astro';
import HighlightCard from '../components/HighlightCard.astro';
import Eyebrow from '../components/Eyebrow.astro';
import PullQuote from '../components/PullQuote.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import Button from '../components/Button.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'index');
if (!entry) throw new Error('Content entry not found: index');

const { hero, highlights } = entry.data as {
  hero: { heading: string; subheading: string; cta: string; cta_link: string };
  highlights: Array<{ title: string; description: string; icon: string }>;
};
---

<HeroHubLayout title={entry.data.title} description={entry.data.description}>
  <!-- 1. Hero (verde_vital register) -->
  <Hero
    slot="hero"
    heading={hero.heading}
    subheading={hero.subheading}
    cta={hero.cta}
    ctaLink={hero.cta_link}
    backgroundImage="/images/hero/estufa-modulos.jpg"
    eyebrow="Biotoco"
    register="verde_vital"
    locationLine="Fabricado em Rio Claro, SP"
  />

  <!-- 2+3. Intro statement + Highlight cards (off_white, py-28) -->
  <section class="bg-biotoco-off_white py-28 max-lg:py-20 max-md:py-14">
    <div class="max-w-[1312px] mx-auto px-16 max-lg:px-10 max-md:px-6">
      <!-- Intro: two-column statement -->
      <ScrollReveal>
        <div class="grid grid-cols-2 gap-20 max-lg:grid-cols-1 max-lg:gap-10">
          <h2 class="font-display font-bold text-[36px] leading-[1.2] tracking-[-0.01em] text-biotoco-azul_profundo [text-wrap:pretty] max-lg:text-[30px] max-md:text-[26px]">
            Módulos biodegradáveis que transformam resíduos agroindustriais brasileiros no futuro do cultivo sustentável.
          </h2>
          <p class="text-[17px] leading-[1.7] text-biotoco-azul_texto_2 [text-wrap:pretty] self-center">
            Bagaço de cana-de-açúcar, fibra de coco e celulose kraft — três fibras em três escalas, unidas por ligantes naturais de mandioca. Desenvolvimento vegetal superior, alinhado aos princípios da economia circular.
          </p>
        </div>
      </ScrollReveal>

      <!-- Highlight cards -->
      <div class="mt-16 max-md:mt-10 grid grid-cols-3 gap-6 max-lg:grid-cols-1 max-lg:gap-4">
        {highlights.map((h, i) => (
          <ScrollReveal delay={i * 100}>
            <HighlightCard
              title={h.title}
              description={h.description}
              index={i + 1}
            />
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Como funciona (areia band, py-28) -->
  <section class="bg-biotoco-areia py-28 max-lg:py-20 max-md:py-14">
    <div class="max-w-[1312px] mx-auto px-16 max-lg:px-10 max-md:px-6">
      <div class="grid grid-cols-[1fr_440px] gap-20 items-start max-lg:grid-cols-1 max-lg:gap-12">
        <div>
          <ScrollReveal>
            <Eyebrow color="biotoco-verde_vital">Como funciona</Eyebrow>
            <h2 class="font-display font-bold text-[36px] leading-[1.2] tracking-[-0.01em] text-biotoco-azul_profundo [text-wrap:pretty] mt-4 mb-12 max-lg:text-[30px] max-md:text-[26px] max-md:mb-8">
              Da fábrica ao campo, sem plástico
            </h2>
          </ScrollReveal>
          <div class="flex flex-col">
            <ScrollReveal>
              <div class="grid grid-cols-[48px_1fr] gap-6 py-6 border-t border-hairline max-md:grid-cols-[36px_1fr] max-md:gap-4">
                <span class="font-display font-extrabold text-[22px] text-biotoco-verde_vital/40">01</span>
                <div>
                  <strong class="font-display font-bold text-[19px] text-biotoco-azul_profundo">Fabricação Natural</strong>
                  <p class="mt-1 text-base leading-[1.6] text-biotoco-azul_texto_2">Bagaço de cana, fibra de coco, celulose kraft, amido de mandioca e ácido cítrico — moldados a vácuo.</p>
                </div>
              </div>
            </ScrollReveal>
            <ScrollReveal delay={80}>
              <div class="grid grid-cols-[48px_1fr] gap-6 py-6 border-t border-hairline max-md:grid-cols-[36px_1fr] max-md:gap-4">
                <span class="font-display font-extrabold text-[22px] text-biotoco-verde_vital/40">02</span>
                <div>
                  <strong class="font-display font-bold text-[19px] text-biotoco-azul_profundo">Três Escalas de Fibra</strong>
                  <p class="mt-1 text-base leading-[1.6] text-biotoco-azul_texto_2">O trio confere estrutura mecânica do viveiro ao campo.</p>
                </div>
              </div>
            </ScrollReveal>
            <ScrollReveal delay={160}>
              <div class="grid grid-cols-[48px_1fr] gap-6 py-6 border-t border-hairline max-md:grid-cols-[36px_1fr] max-md:gap-4">
                <span class="font-display font-extrabold text-[22px] text-biotoco-verde_vital/40">03</span>
                <div>
                  <strong class="font-display font-bold text-[19px] text-biotoco-azul_profundo">Barreira Hidrofóbica</strong>
                  <p class="mt-1 text-base leading-[1.6] text-biotoco-azul_texto_2">Lignina natural retém água com CRA de 300–400% nas semanas críticas pós-transplante.</p>
                </div>
              </div>
            </ScrollReveal>
            <ScrollReveal delay={240}>
              <div class="grid grid-cols-[48px_1fr] gap-6 py-6 border-t border-hairline border-b max-md:grid-cols-[36px_1fr] max-md:gap-4">
                <span class="font-display font-extrabold text-[22px] text-biotoco-verde_vital/40">04</span>
                <div>
                  <strong class="font-display font-bold text-[19px] text-biotoco-azul_profundo">Plantio Direto</strong>
                  <p class="mt-1 text-base leading-[1.6] text-biotoco-azul_texto_2">O módulo vai inteiro ao solo — sem desentubetamento, sem logística reversa.</p>
                </div>
              </div>
            </ScrollReveal>
          </div>
        </div>
        <ScrollReveal direction="right">
          <img
            src="/images/product/bg7-textura.jpg"
            alt="Detalhe da textura do módulo BIOTOCO"
            class="w-full h-[520px] object-cover leaf-corner max-lg:h-[360px] max-md:h-[280px]"
            loading="lazy"
          />
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- 5. Full-bleed photo break -->
  <section class="relative h-[520px] max-md:h-auto">
    <!-- Desktop/Tablet: photo with caption chip -->
    <div class="relative h-full max-md:hidden">
      <img
        src="/images/mudas/bandeja-viveiro.jpg"
        alt="Bandejas de mudas em viveiro com módulos BIOTOCO"
        class="absolute inset-0 size-full object-cover"
        loading="lazy"
      />
      <div class="absolute left-16 bottom-10 bg-biotoco-azul_profundo text-biotoco-off_white rounded-[10px] p-6 max-w-[460px] max-lg:left-10">
        <p class="eyebrow text-biotoco-verde_vital mb-2">Em campo</p>
        <p class="text-[15px] leading-[1.6]">Módulos BIOTOCO em bandejas convencionais de viveiro — adaptáveis a qualquer sistema de produção de mudas.</p>
      </div>
    </div>
    <!-- Mobile: static bar below photo -->
    <div class="md:hidden">
      <div class="relative h-[300px]">
        <img
          src="/images/mudas/bandeja-viveiro.jpg"
          alt="Bandejas de mudas em viveiro com módulos BIOTOCO"
          class="absolute inset-0 size-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="bg-biotoco-azul_profundo text-biotoco-off_white p-6">
        <p class="eyebrow text-biotoco-verde_vital mb-2">Em campo</p>
        <p class="text-[15px] leading-[1.6]">Módulos BIOTOCO em bandejas convencionais de viveiro — adaptáveis a qualquer sistema de produção de mudas.</p>
      </div>
    </div>
  </section>

  <!-- 6. Solutions index (azul_profundo, py-28) -->
  <section class="bg-biotoco-azul_profundo text-biotoco-off_white py-28 max-lg:py-20 max-md:py-14">
    <div class="max-w-[1312px] mx-auto px-16 max-lg:px-10 max-md:px-6">
      <ScrollReveal>
        <Eyebrow color="biotoco-verde_vital">Soluções</Eyebrow>
        <h2 class="font-display font-bold text-[40px] leading-[1.15] tracking-[-0.01em] text-biotoco-off_white [text-wrap:pretty] mt-4 mb-12 max-lg:text-[30px] max-md:text-[26px] max-md:mb-8">
          Soluções por Segmento
        </h2>
      </ScrollReveal>
      <!-- Desktop/Tablet rows -->
      <div class="flex flex-col max-md:hidden">
        <a href="/para-viveiros" class="grid grid-cols-[80px_1fr_380px_40px] items-center gap-8 py-[30px] border-t border-hairline-dark no-underline hover:no-underline hover:bg-biotoco-off_white/5 transition-colors max-lg:grid-cols-[60px_1fr_200px_32px] max-lg:gap-4">
          <span class="font-display font-extrabold text-[22px] text-biotoco-off_white/35">01</span>
          <span class="font-display font-bold text-[30px] leading-[1.2] text-biotoco-off_white max-lg:text-[22px]">Para Viveiros</span>
          <span class="text-base text-biotoco-off_white/70">Qualidade e eficiência na produção de mudas</span>
          <span class="font-display text-[26px] text-biotoco-verde_vital">→</span>
        </a>
        <a href="/solucoes/para-reflorestamento" class="grid grid-cols-[80px_1fr_380px_40px] items-center gap-8 py-[30px] border-t border-hairline-dark no-underline hover:no-underline hover:bg-biotoco-off_white/5 transition-colors max-lg:grid-cols-[60px_1fr_200px_32px] max-lg:gap-4">
          <span class="font-display font-extrabold text-[22px] text-biotoco-off_white/35">02</span>
          <span class="font-display font-bold text-[30px] leading-[1.2] text-biotoco-off_white max-lg:text-[22px]">Para Reflorestamento</span>
          <span class="text-base text-biotoco-off_white/70">Sucesso e impacto em restauração florestal</span>
          <span class="font-display text-[26px] text-biotoco-verde_vital">→</span>
        </a>
        <a href="/solucoes/para-cooperativas" class="grid grid-cols-[80px_1fr_380px_40px] items-center gap-8 py-[30px] border-t border-hairline-dark no-underline hover:no-underline hover:bg-biotoco-off_white/5 transition-colors max-lg:grid-cols-[60px_1fr_200px_32px] max-lg:gap-4">
          <span class="font-display font-extrabold text-[22px] text-biotoco-off_white/35">03</span>
          <span class="font-display font-bold text-[30px] leading-[1.2] text-biotoco-off_white max-lg:text-[22px]">Para Cooperativas</span>
          <span class="text-base text-biotoco-off_white/70">Inovação e sustentabilidade na cadeia produtiva</span>
          <span class="font-display text-[26px] text-biotoco-verde_vital">→</span>
        </a>
        <a href="/culturas" class="grid grid-cols-[80px_1fr_380px_40px] items-center gap-8 py-[30px] border-t border-hairline-dark border-b border-b-hairline-dark no-underline hover:no-underline hover:bg-biotoco-off_white/5 transition-colors max-lg:grid-cols-[60px_1fr_200px_32px] max-lg:gap-4">
          <span class="font-display font-extrabold text-[22px] text-biotoco-off_white/35">04</span>
          <span class="font-display font-bold text-[30px] leading-[1.2] text-biotoco-off_white max-lg:text-[22px]">Culturas</span>
          <span class="text-base text-biotoco-off_white/70">BIOTOCO adaptado a cada espécie</span>
          <span class="font-display text-[26px] text-biotoco-verde_vital">→</span>
        </a>
      </div>
      <!-- Mobile rows -->
      <div class="flex flex-col md:hidden">
        <a href="/para-viveiros" class="flex justify-between items-center py-5 border-t border-hairline-dark no-underline hover:no-underline">
          <span class="font-display font-bold text-[21px] text-biotoco-off_white">Para Viveiros</span>
          <span class="font-display text-[22px] text-biotoco-verde_vital">→</span>
        </a>
        <a href="/solucoes/para-reflorestamento" class="flex justify-between items-center py-5 border-t border-hairline-dark no-underline hover:no-underline">
          <span class="font-display font-bold text-[21px] text-biotoco-off_white">Para Reflorestamento</span>
          <span class="font-display text-[22px] text-biotoco-verde_vital">→</span>
        </a>
        <a href="/solucoes/para-cooperativas" class="flex justify-between items-center py-5 border-t border-hairline-dark no-underline hover:no-underline">
          <span class="font-display font-bold text-[21px] text-biotoco-off_white">Para Cooperativas</span>
          <span class="font-display text-[22px] text-biotoco-verde_vital">→</span>
        </a>
        <a href="/culturas" class="flex justify-between items-center py-5 border-t border-hairline-dark border-b border-b-hairline-dark no-underline hover:no-underline">
          <span class="font-display font-bold text-[21px] text-biotoco-off_white">Culturas</span>
          <span class="font-display text-[22px] text-biotoco-verde_vital">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 7. Pilares (off_white, py-28) -->
  <section class="bg-biotoco-off_white py-28 max-lg:py-20 max-md:py-14">
    <div class="max-w-[1312px] mx-auto px-16 max-lg:px-10 max-md:px-6">
      <ScrollReveal>
        <Eyebrow color="biotoco-verde_vital">Nossos pilares</Eyebrow>
        <h2 class="font-display font-bold text-[36px] leading-[1.2] tracking-[-0.01em] text-biotoco-azul_profundo [text-wrap:pretty] mt-4 mb-12 max-lg:text-[30px] max-md:text-[26px] max-md:mb-8">
          O que nos move
        </h2>
      </ScrollReveal>
      <div class="grid grid-cols-2 gap-x-16 gap-y-0 max-md:grid-cols-1">
        <ScrollReveal>
          <div class="border-t-2 border-biotoco-verde_vital pt-6 pb-8">
            <h3 class="font-display font-bold text-xl text-biotoco-azul_profundo mb-2">Sustentabilidade</h3>
            <p class="text-base leading-[1.6] text-biotoco-azul_texto_2">100% biodegradáveis, fabricados com resíduos agroindustriais brasileiros. Zero plástico.</p>
          </div>
        </ScrollReveal>
        <ScrollReveal delay={80}>
          <div class="border-t-2 border-biotoco-verde_vital pt-6 pb-8">
            <h3 class="font-display font-bold text-xl text-biotoco-azul_profundo mb-2">Ciência</h3>
            <p class="text-base leading-[1.6] text-biotoco-azul_texto_2">Validado por EMBRAPA-solo e UFRRJ, com dados de campo e laboratório reais.</p>
          </div>
        </ScrollReveal>
        <ScrollReveal delay={160}>
          <div class="border-t-2 border-biotoco-verde_vital pt-6 pb-8">
            <h3 class="font-display font-bold text-xl text-biotoco-azul_profundo mb-2">Resultados</h3>
            <p class="text-base leading-[1.6] text-biotoco-azul_texto_2">30–35% de crescimento mais rápido, comprovado em viveiros parceiros.</p>
          </div>
        </ScrollReveal>
        <ScrollReveal delay={240}>
          <div class="border-t-2 border-biotoco-verde_vital pt-6 pb-8">
            <h3 class="font-display font-bold text-xl text-biotoco-azul_profundo mb-2">Economia Circular</h3>
            <p class="text-base leading-[1.6] text-biotoco-azul_texto_2">Resíduos agroindustriais transformados em tecnologia que cultiva o futuro.</p>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- 8. Testimonial (bege_terra band) -->
  <!-- TODO: replace with real testimonial quote from a partner/client -->
  <PullQuote
    variant="side"
    eyebrow="Parceiros"
    quote="Tecnologia validada por EMBRAPA-solo e UFRRJ, testada em viveiros como Reserva Natural Vale, Suzano e SOS Mata Atlântica."
    attribution="— Parceiros e Instituições"
  />

  <!-- 9. Final CTA (off_white, py-28, centered) -->
  <section class="bg-biotoco-off_white py-28 max-lg:py-20 max-md:py-14">
    <div class="max-w-[1312px] mx-auto px-16 max-lg:px-10 max-md:px-6 text-center">
      <ScrollReveal>
        <h2 class="font-display font-bold text-[40px] leading-[1.15] tracking-[-0.01em] text-biotoco-azul_profundo [text-wrap:pretty] max-lg:text-[30px] max-md:text-[26px]">
          Mudando o mundo, uma muda por vez
        </h2>
        <div class="mt-8">
          <Button href="/contato" variant="primary" size="lg">
            Fale Conosco
          </Button>
        </div>
      </ScrollReveal>
    </div>
  </section>
</HeroHubLayout>
