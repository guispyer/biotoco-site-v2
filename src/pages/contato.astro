---
import SegmentValueLayout from '../layouts/SegmentValueLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'contato');
if (!entry) throw new Error('Content entry not found: contato');

const {
  title,
  description,
  contact_info,
  social_media,
} = entry.data as {
  title: string;
  description: string;
  contact_info: { phone: string; email: string; address: string };
  social_media: { linkedin: string; instagram: string };
};
---

<SegmentValueLayout title={title} description={description} fullBleed>
  <!-- Hero — bege_terra register -->
  <Hero
    slot="hero"
    heading="Fale com a Biotoco"
    subheading={description}
    cta="Enviar mensagem"
    ctaLink={`mailto:${contact_info.email}`}
    eyebrow="Contato"
    register="bege_terra"
  />

  <!-- Contact cards — off_white (single source of contact info) -->
  <section class="bg-biotoco-off_white py-28 max-lg:py-20 max-md:py-14">
    <div class="max-w-[1312px] mx-auto px-16 max-lg:px-10 max-md:px-6">
      <SectionTitle tag="h2" eyebrow="Canais" registerColor="biotoco-bege_terra" class="mb-12">
        Canais de contato
      </SectionTitle>
      <div class="grid gap-6 md:grid-cols-3">
        <!-- Email -->
        <ScrollReveal>
          <a href={`mailto:${contact_info.email}`} class="group block border border-hairline rounded-[14px] bg-biotoco-off_white_claro p-6 transition-colors hover:border-biotoco-azul_profundo/30">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-[10px] bg-biotoco-verde_vital/10">
              <svg class="h-5 w-5 text-biotoco-verde_vital" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-display text-base font-bold text-biotoco-azul_profundo group-hover:text-biotoco-verde_vital transition-colors">E-mail</h3>
            <p class="mt-1 text-[15px] text-biotoco-azul_texto_2">{contact_info.email}</p>
          </a>
        </ScrollReveal>
        <!-- Phone -->
        <ScrollReveal delay={100}>
          <a href={`tel:${contact_info.phone.replace(/\D/g, '')}`} class="group block border border-hairline rounded-[14px] bg-biotoco-off_white_claro p-6 transition-colors hover:border-biotoco-azul_profundo/30">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-[10px] bg-biotoco-terracota/10">
              <svg class="h-5 w-5 text-biotoco-terracota" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <h3 class="font-display text-base font-bold text-biotoco-azul_profundo group-hover:text-biotoco-terracota transition-colors">Telefone</h3>
            <p class="mt-1 text-[15px] text-biotoco-azul_texto_2">{contact_info.phone}</p>
          </a>
        </ScrollReveal>
        <!-- Address -->
        <ScrollReveal delay={200}>
          <div class="border border-hairline rounded-[14px] bg-biotoco-off_white_claro p-6">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-[10px] bg-biotoco-azul_profundo/10">
              <svg class="h-5 w-5 text-biotoco-azul_profundo" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-display text-base font-bold text-biotoco-azul_profundo">Endereço</h3>
            <p class="mt-1 text-[15px] text-biotoco-azul_texto_2">{contact_info.address}</p>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- Social media + form placeholder — areia band -->
  <section class="bg-biotoco-areia py-28 max-lg:py-20 max-md:py-14">
    <div class="max-w-[1312px] mx-auto px-16 max-lg:px-10 max-md:px-6">
      <div class="grid gap-20 md:grid-cols-2 max-md:gap-14">
        <!-- Social media -->
        {social_media && (
          <div>
            <SectionTitle tag="h2" eyebrow="Redes" registerColor="biotoco-bege_terra" class="mb-8">
              Redes sociais
            </SectionTitle>
            <div class="flex flex-wrap gap-4">
              {social_media.linkedin && (
                <a href={social_media.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border border-hairline rounded-[10px] bg-biotoco-off_white_claro px-5 py-3 text-[15px] font-semibold text-biotoco-azul_profundo transition-colors hover:border-biotoco-azul_profundo/30">
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                  LinkedIn
                </a>
              )}
              {social_media.instagram && (
                <a href={social_media.instagram} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border border-hairline rounded-[10px] bg-biotoco-off_white_claro px-5 py-3 text-[15px] font-semibold text-biotoco-azul_profundo transition-colors hover:border-biotoco-azul_profundo/30">
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                  </svg>
                  Instagram
                </a>
              )}
            </div>
          </div>
        )}

        <!-- Contact form placeholder -->
        <div>
          <SectionTitle tag="h2" eyebrow="Mensagem" registerColor="biotoco-bege_terra" class="mb-8">
            Envie uma mensagem
          </SectionTitle>
          <!-- TODO: Contact form (Preact island) -->
          <div class="border border-hairline rounded-[14px] bg-biotoco-off_white_claro px-7 py-10 text-center">
            <p class="text-[17px] text-biotoco-azul_texto">Formulário em breve.</p>
            <p class="mt-2 text-[15px] text-biotoco-cinza_apoio">Por enquanto, envie um e-mail para <a href={`mailto:${contact_info.email}`} class="text-biotoco-verde_vital font-medium hover:underline">{contact_info.email}</a>.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</SegmentValueLayout>
