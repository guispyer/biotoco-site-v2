---
interface Props {
  value: string;
  unit: string;
  basis: string;
  comparison: string;
  source: string;
}

const { value, unit, basis, comparison, source } = Astro.props;
---

<div class="rounded-biotocoXl bg-biotoco-verde_escuro px-6 py-10 text-center md:px-12">
  <p class="font-body text-sm font-semibold uppercase tracking-wide text-biotoco-off_white/60">
    Impacto mensurável
  </p>
  <p class="mt-3 font-display text-5xl font-bold text-biotoco-off_white md:text-6xl">
    {value}
  </p>
  <p class="mt-1 font-display text-xl font-bold text-biotoco-verde_vital">
    {unit}
  </p>
  <p class="mx-auto mt-4 max-w-md font-body text-sm leading-relaxed text-biotoco-off_white/80">
    {basis} — {comparison}
  </p>
  <p class="mt-4 font-body text-xs text-biotoco-off_white/50">
    Fonte: {source}
  </p>
</div>
