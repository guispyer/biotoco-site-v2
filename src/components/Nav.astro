---
const currentPath = Astro.url.pathname;

const mainLinks = [
  { href: '/para-viveiros', label: 'Para Viveiros' },
  {
    href: '/solucoes', label: 'Soluções',
    children: [
      { href: '/culturas', label: 'Culturas' },
      { href: '/solucoes/para-cooperativas', label: 'Para Cooperativas' },
      { href: '/solucoes/para-reflorestamento', label: 'Para Reflorestamento' },
    ],
  },
  { href: '/o-modulo', label: 'O Módulo' },
  { href: '/ciencia', label: 'Ciência' },
  { href: '/sobre', label: 'Sobre' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

function isDropdownActive(link: typeof mainLinks[1]): boolean {
  if ('children' in link && link.children) {
    return link.children.some((c) => isActive(c.href)) || isActive(link.href);
  }
  return isActive(link.href);
}
---

<header class="sticky top-0 z-50 bg-biotoco-off_white border-b border-hairline max-md:h-[60px]" aria-label="Navegação principal">
  <div class="flex items-center justify-between h-20 px-16 max-lg:px-10 max-md:h-[60px] max-md:px-5">
    {/* Logo */}
    <a href="/" class="shrink-0" aria-label="Biotoco — Página inicial">
      <img
        src="/logos/logotipo-principal-azul.png"
        alt="Biotoco"
        class="h-[30px] w-auto max-md:h-6"
      />
    </a>

    {/* Desktop links — visible from md (768px) */}
    <nav class="hidden items-center gap-9 max-lg:gap-6 md:flex">
      {mainLinks.map((link) =>
        'children' in link && link.children ? (
          <div class="group relative">
            <a
              href={link.href}
              class:list={[
                'inline-flex items-center gap-1 text-[15px] font-medium transition-colors',
                isDropdownActive(link)
                  ? 'text-biotoco-verde_escuro font-semibold'
                  : 'text-biotoco-azul_profundo hover:text-biotoco-verde_escuro',
              ]}
            >
              {link.label}
              <svg class="h-3.5 w-3.5 transition-transform group-hover:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            </a>
            <div class="pointer-events-none absolute left-0 top-full pt-2 opacity-0 transition-all duration-150 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100">
              <div class="min-w-[200px] rounded-biotocoMd bg-biotoco-off_white border border-hairline py-2">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      'block px-4 py-2 text-[15px] font-medium transition-colors',
                      isActive(child.href)
                        ? 'text-biotoco-verde_escuro font-semibold'
                        : 'text-biotoco-azul_profundo hover:text-biotoco-verde_escuro',
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              'text-[15px] font-medium transition-colors',
              isActive(link.href)
                ? 'text-biotoco-verde_escuro font-semibold'
                : 'text-biotoco-azul_profundo hover:text-biotoco-verde_escuro',
            ]}
          >
            {link.label}
          </a>
        )
      )}
      <a
        href="/contato"
        class="btn-primary text-[15px] px-[22px] py-[11px]"
      >
        Fale Conosco
      </a>
    </nav>

    {/* Mobile hamburger — 24px Lucide menu, stroke azul, stroke-width 1.75 */}
    <button
      type="button"
      class="flex h-11 w-11 items-center justify-center md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menu de navegação"
      id="menu-toggle"
    >
      <svg class="h-6 w-6 text-biotoco-azul_profundo" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path class="menu-open" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        <path class="menu-close hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  {/* Mobile menu */}
  <div
    id="mobile-menu"
    class="hidden border-t border-hairline bg-biotoco-off_white px-6 pb-6 pt-4 md:hidden"
  >
    <div class="flex flex-col gap-4">
      {mainLinks.map((link) =>
        'children' in link && link.children ? (
          <div>
            <button
              type="button"
              class:list={[
                'mobile-dropdown-toggle flex w-full items-center justify-between text-base font-medium transition-colors',
                isDropdownActive(link) ? 'text-biotoco-verde_escuro font-semibold' : 'text-biotoco-azul_profundo',
              ]}
              aria-expanded="false"
            >
              {link.label}
              <svg class="mobile-chevron h-4 w-4 transition-transform" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            </button>
            <div class="mobile-dropdown-content hidden mt-2 flex flex-col gap-2 pl-4">
              <a
                href={link.href}
                class:list={[
                  'text-[15px] font-medium transition-colors',
                  isActive(link.href) ? 'text-biotoco-verde_escuro font-semibold' : 'text-biotoco-azul_texto_2 hover:text-biotoco-verde_escuro',
                ]}
              >
                Ver Todas
              </a>
              {link.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    'text-[15px] font-medium transition-colors',
                    isActive(child.href) ? 'text-biotoco-verde_escuro font-semibold' : 'text-biotoco-azul_texto_2 hover:text-biotoco-verde_escuro',
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              'text-base font-medium transition-colors',
              isActive(link.href)
                ? 'text-biotoco-verde_escuro font-semibold'
                : 'text-biotoco-azul_profundo hover:text-biotoco-verde_escuro',
            ]}
          >
            {link.label}
          </a>
        )
      )}
      <a
        href="/contato"
        class="btn-primary mt-2 text-center text-base"
      >
        Fale Conosco
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    const openIcon = toggle.querySelector('.menu-open');
    const closeIcon = toggle.querySelector('.menu-close');

    function setOpen(open: boolean) {
      toggle!.setAttribute('aria-expanded', String(open));
      menu!.classList.toggle('hidden', !open);
      openIcon?.classList.toggle('hidden', open);
      closeIcon?.classList.toggle('hidden', !open);
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!isOpen);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });
  }

  document.querySelectorAll('.mobile-dropdown-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling as HTMLElement | null;
      const chevron = btn.querySelector('.mobile-chevron') as HTMLElement | null;
      if (!content) return;
      const isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
      chevron?.classList.toggle('rotate-180', !isOpen);
    });
  });
</script>
