---
interface Props {
  lab: string;
  what: string;
  key_results: string[];
}

const { lab, what, key_results } = Astro.props;
---

<div class="rounded-biotocoLg border border-borderSubtle bg-white shadow-biotoco1 transition-shadow hover:shadow-biotoco2">
  <div class="border-b border-borderSubtle px-6 py-4">
    <h3 class="font-display text-base font-bold text-biotoco-azul_profundo">{lab}</h3>
    <p class="mt-1 font-body text-sm text-fgMuted">{what}</p>
  </div>
  <ul class="px-6 py-4 space-y-2">
    {key_results.map((r) => (
      <li class="flex items-center gap-2 font-body text-sm text-fg/80">
        <svg class="h-4 w-4 shrink-0 text-biotoco-verde_vital" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        {r}
      </li>
    ))}
  </ul>
</div>
