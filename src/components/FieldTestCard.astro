---
interface Props {
  institution: string;
  type: string;
  key_metric: string;
  crop: string;
  contacts?: string;
}

const { institution, type, key_metric, crop, contacts } = Astro.props;
---

<div class="rounded-biotocoLg border border-borderSubtle bg-white p-6 shadow-biotoco1 transition-shadow hover:shadow-biotoco2">
  <div class="flex items-start gap-3">
    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-biotoco-verde_escuro/10">
      <svg class="h-4 w-4 text-biotoco-verde_escuro" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
      </svg>
    </div>
    <div class="flex-1">
      <h3 class="font-display text-base font-bold text-biotoco-azul_profundo">{institution}</h3>
      <p class="mt-0.5 font-body text-xs text-fgMuted">{type}</p>
    </div>
  </div>
  <p class="mt-3 font-body text-sm leading-relaxed text-fg/80">{key_metric}</p>
  <div class="mt-3 flex flex-wrap items-center gap-2">
    <span class="rounded-biotocoSm bg-biotoco-verde_vital/10 px-2.5 py-1 font-body text-xs font-semibold text-biotoco-verde_vital">
      {crop}
    </span>
  </div>
</div>
