---
interface Props {
  quote: string;
  attribution?: string;
  variant?: 'side' | 'centered';
  photoSrc?: string;
  photoAlt?: string;
  eyebrow?: string;
  followUp?: string;
}

const {
  quote,
  attribution,
  variant = 'side',
  photoSrc,
  photoAlt = '',
  eyebrow,
  followUp,
} = Astro.props;
---

<section class="relative overflow-hidden bg-biotoco-bege_terra py-24 max-lg:py-20 max-md:py-14">
  <div class="absolute -left-16 -top-16 w-80 h-64 bg-biotoco-marrom_profundo/30 rounded-br-full" aria-hidden="true"></div>
  <div class="relative max-w-[1312px] mx-auto px-16 max-lg:px-10 max-md:px-6">
    {variant === 'centered' ? (
      <div class="max-w-[900px] mx-auto text-center">
        {eyebrow && <p class="eyebrow text-biotoco-marrom_profundo mb-4">{eyebrow}</p>}
        <blockquote class="font-display font-bold text-[46px] leading-[1.25] text-biotoco-azul_profundo [text-wrap:pretty] max-lg:text-[34px] max-md:text-[26px]">
          {quote}
        </blockquote>
        {followUp && (
          <p class="mt-8 max-w-[560px] mx-auto text-lg leading-[1.6] text-biotoco-marrom_profundo [text-wrap:pretty]">
            {followUp}
          </p>
        )}
        {attribution && (
          <p class="mt-6 text-[15px] font-medium text-biotoco-marrom_profundo">{attribution}</p>
        )}
      </div>
    ) : (
      <div class:list={[
        photoSrc ? 'grid grid-cols-[1fr_380px] gap-16 items-center max-lg:grid-cols-1 max-lg:gap-10' : 'max-w-[900px]'
      ]}>
        <div>
          {eyebrow && <p class="eyebrow text-biotoco-marrom_profundo mb-4">{eyebrow}</p>}
          <blockquote class="font-display font-bold text-[32px] leading-[1.3] text-biotoco-azul_profundo [text-wrap:pretty] max-md:text-[24px]">
            {quote}
          </blockquote>
          {attribution && (
            <p class="mt-6 text-[15px] font-medium text-biotoco-marrom_profundo">{attribution}</p>
          )}
        </div>
        {photoSrc && (
          <div class="overflow-hidden max-lg:order-first">
            <img
              src={photoSrc}
              alt={photoAlt}
              class="w-full h-[420px] object-cover rounded-[0_120px_0_120px] max-md:h-[280px]"
              loading="lazy"
            />
          </div>
        )}
      </div>
    )}
  </div>
</section>
