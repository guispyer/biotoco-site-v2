---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary-dark' | 'on-bege' | 'tertiary';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
} = Astro.props;

const sizeClasses = {
  sm: 'px-[22px] py-[11px] text-[15px]',
  md: 'px-[26px] py-[13px] text-[15px]',
  lg: 'px-[30px] py-4 text-[17px]',
};

const variantClasses = {
  primary: 'btn-primary',
  'secondary-dark': 'btn-secondary-dark',
  'on-bege': 'btn-on-bege',
  tertiary: 'text-biotoco-verde_vital hover:underline',
};

const base =
  'inline-flex items-center justify-center font-semibold focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-biotoco-verde_vital';

const classes = [base, sizeClasses[size], variantClasses[variant], className]
  .filter(Boolean)
  .join(' ');
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}
