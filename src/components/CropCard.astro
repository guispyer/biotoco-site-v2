---
interface Props {
  name: string;
  models: string[];
  key_benefit: string;
  pain_addressed: string;
  segment: string;
  validated_by: string[];
  status: string;
}

const { name, models, key_benefit, pain_addressed, segment, validated_by, status } = Astro.props;

const statusColor = status.toLowerCase().includes('disponível')
  ? 'bg-biotoco-verde_vital/10 text-biotoco-verde_vital'
  : 'bg-biotoco-bege_terra/10 text-biotoco-bege_terra';
---

<div class="flex flex-col rounded-biotocoLg border border-borderSubtle bg-white shadow-biotoco1 transition-shadow hover:shadow-biotoco2">
  <!-- Header -->
  <div class="border-b border-borderSubtle px-6 pt-6 pb-4">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-display text-xl font-bold text-biotoco-azul_profundo">{name}</h3>
      <span class:list={['shrink-0 rounded-full px-3 py-1 font-body text-xs font-semibold', statusColor]}>
        {status}
      </span>
    </div>
    <!-- Model badges -->
    <div class="mt-3 flex flex-wrap gap-2">
      {models.map((m) => (
        <span class="rounded-biotocoSm bg-biotoco-azul_profundo/10 px-2.5 py-1 font-body text-xs font-semibold text-biotoco-azul_profundo">
          {m}
        </span>
      ))}
    </div>
  </div>

  <!-- Body -->
  <div class="flex flex-1 flex-col gap-4 px-6 py-5">
    <div>
      <h4 class="mb-1 font-body text-xs font-semibold uppercase tracking-wide text-biotoco-verde_vital">Benefício principal</h4>
      <p class="font-body text-sm leading-relaxed text-fg/80">{key_benefit}</p>
    </div>
    <div>
      <h4 class="mb-1 font-body text-xs font-semibold uppercase tracking-wide text-biotoco-terracota">Dor que resolve</h4>
      <p class="font-body text-sm leading-relaxed text-fg/80">{pain_addressed}</p>
    </div>
  </div>

  <!-- Footer -->
  <div class="border-t border-borderSubtle px-6 py-4">
    <p class="mb-2 font-body text-xs text-fgMuted">
      <span class="font-semibold">Segmento:</span> {segment}
    </p>
    <div class="flex flex-wrap gap-1.5">
      {validated_by.map((v) => (
        <span class="rounded-biotocoSm bg-biotoco-off_white px-2 py-0.5 font-body text-xs text-fgMuted">
          {v}
        </span>
      ))}
    </div>
  </div>
</div>
