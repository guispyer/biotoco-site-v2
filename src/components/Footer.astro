---
const navColumns = [
  {
    heading: 'Soluções',
    links: [
      { href: '/para-viveiros', label: 'Para Viveiros' },
      { href: '/solucoes/para-cooperativas', label: 'Para Cooperativas' },
      { href: '/solucoes/para-reflorestamento', label: 'Para Reflorestamento' },
      { href: '/culturas', label: 'Culturas' },
    ],
  },
  {
    heading: 'Biotoco',
    links: [
      { href: '/o-modulo', label: 'O Módulo' },
      { href: '/ciencia', label: 'Ciência' },
      { href: '/sustentabilidade', label: 'Sustentabilidade' },
      { href: '/sobre', label: 'Sobre' },
      { href: '/contato', label: 'Contato' },
    ],
  },
];
---

<footer class="relative overflow-hidden bg-biotoco-azul_profundo text-biotoco-off_white/75">
  <div class="texture-dots pointer-events-none absolute inset-0" aria-hidden="true"></div>

  <div class="relative p-16 max-md:p-8">
    <div class="flex justify-between items-start max-md:flex-col max-md:gap-10">
      {/* Logo + tagline */}
      <div>
        <a href="/" aria-label="Biotoco — Página inicial">
          <img
            src="/logos/logotipo-negativo-branco.png"
            alt="Biotoco"
            class="h-[34px] w-auto"
          />
        </a>
        <p class="mt-4 text-sm max-w-80 leading-relaxed">
          Tecnologia que Cultiva o Futuro
        </p>
      </div>

      {/* Nav columns */}
      <div class="flex gap-20 text-[15px] leading-[2.2] max-md:gap-12 max-sm:flex-col max-sm:gap-8">
        {navColumns.map((col) => (
          <div>
            <p class="eyebrow text-biotoco-verde_vital mb-4">{col.heading}</p>
            <ul class="space-y-0">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-biotoco-off_white/75 transition-colors hover:text-biotoco-off_white hover:no-underline"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  {/* Bottom bar */}
  <div class="relative border-t border-hairline-dark">
    <div class="flex flex-col items-center justify-between gap-4 px-16 py-6 text-[13px] text-biotoco-off_white/60 md:flex-row max-md:px-8">
      <p>
        &copy; {new Date().getFullYear()} TOCO Engenharia e Inova&ccedil;&atilde;o Ambiental Ltda &bull;
        CNPJ 27.969.574/0001-29 &bull;
        Patente BR 102020013631-3
      </p>

      {/* Social icons */}
      <div class="flex items-center gap-4">
        <a
          href="https://www.linkedin.com/company/biotoco"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-biotoco-verde_vital"
          aria-label="Biotoco no LinkedIn"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
        <a
          href="https://www.instagram.com/biotoco.sustentavel"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-biotoco-verde_vital"
          aria-label="Biotoco no Instagram"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
